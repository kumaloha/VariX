[Unit]
Description=VariX memory API
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=varix
Group=varix
EnvironmentFile=/etc/varix/varix.env
WorkingDirectory=/opt/varix
ExecStart=/opt/varix/bin/varix serve --addr 127.0.0.1:8000
Restart=on-failure
RestartSec=5
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ReadWritePaths=/var/lib/varix /opt/varix

[Install]
WantedBy=multi-user.target
