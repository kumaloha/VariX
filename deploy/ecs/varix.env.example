# Copy to /etc/varix/varix.env on the ECS instance and fill secrets there.

VARIX_ROOT=/opt/varix
INVARIX_CONTENT_DB_PATH=/var/lib/varix/content.db
INVARIX_REUSE_STORED_TRANSCRIPTS=true

# Required when serving beyond localhost. The API binds this token to VARIX_API_USER.
VARIX_API_USER=kuma
VARIX_API_TOKEN=change-me

# LLM / compile / verify.
DASHSCOPE_API_KEY=
COMPILE_MODEL=qwen3-235b-a22b
COMPILE_TIMEOUT_SECONDS=1200

# Optional ASR overrides. ASR_API_KEY falls back to DASHSCOPE_API_KEY when empty.
ASR_API_KEY=
ASR_BASE_URL=
ASR_MODEL=
ASR_RETRY_MAX=3
ASR_RETRY_DELAY_MS=1000
